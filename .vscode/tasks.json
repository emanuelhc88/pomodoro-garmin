{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Current Device",
      "type": "shell",
      "command": "${config:monkeyc.MonkeyC}",
      "args": [
        "-f", "${workspaceFolder}/monkey.jungle",
        "-o", "${workspaceFolder}/bin/toma.prg",
        "-y", "${config:monkeyc.DeveloperKeyPath}",
        "-w"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
